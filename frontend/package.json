  "overrides": {
    "uri-js": "npm:uri-js-replace"
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 8"
  ],
  "gitHooks": {
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "*.js": [
      "eslint . --ext .vue,.js --fix --ignore-path .gitignore",
      "git add"
    ],
    "*.vue": [
      "eslint . --ext .vue,.js --fix --ignore-path .gitignore",
      "git add"
    ]
  }
}
