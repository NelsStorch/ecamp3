{
    "name": "ecamp-core",
    "main": "index.ts",
    "scripts": {
        "lint": "npm run lint:eslint && npm run lint:prettier",
        "lint:eslint": "eslint --fix .",
        "lint:prettier": "prettier --write --ignore-path .prettierignore **/*.{json,md,mjs,ts}",
        "lint:check": "npm run lint:check:eslint && npm run lint:check:prettier",
        "lint:check:eslint": "eslint . --max-warnings 0",
        "lint:check:prettier": "prettier --check --ignore-path .prettierignore **/*.{json,md,mjs,ts}"
    },
    "dependencies": {
        "@pulumi/pulumi": "3.236.0",
        "@pulumi/aws": "7.29.0",
        "@pulumi/awsx": "3.5.0"
    },
    "devDependencies": {
        "@babel/eslint-parser": "7.28.6",
        "@eslint/compat": "2.0.5",
        "@eslint/js": "9.39.4",
        "@types/node": "24.12.3",
        "eslint": "9.39.4",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-n": "18.0.1",
        "eslint-plugin-prettier": "5.5.5",
        "eslint-plugin-promise": "7.3.0",
        "globals": "17.6.0",
        "prettier": "3.8.3"
    }
}
