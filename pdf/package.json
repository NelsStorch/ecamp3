{
  "name": "@ecamp3/client-pdf",
  "description": "Create pdfs for eCamp, using Vue components",
  "type": "module",
  "main": "src/index.js",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "watch": "vite build --watch",
    "preview": "vite preview",
    "test:unit": "vitest --coverage",
    "lint": "npm run lint:eslint && npm run lint:prettier",
    "lint:eslint": "eslint --fix .",
    "lint:prettier": "prettier --write --ignore-path .prettierignore **/*.{css,scss,json,mjs}",
    "lint:check": "npm run lint:check:eslint && npm run lint:check:prettier",
    "lint:check:eslint": "eslint .",
    "lint:check:prettier": "prettier --check --ignore-path .prettierignore **/*.{css,scss,json,mjs}"
  },
  "dependencies": {
    "@vue/runtime-core": "3.5.25",
    "html-entities": "2.6.0",
    "html-parse-stringify": "3.0.1"
  },
  "peerDependencies": {
    "@react-pdf/font": "4.0.3",
    "@react-pdf/layout": "4.4.1",
    "@react-pdf/pdfkit": "4.0.4",
    "@react-pdf/render": "4.3.1",
    "colorjs.io": "0.5.2",
    "lodash-es": "4.17.21",
    "runes": "0.4.3"
  },
  "devDependencies": {
    "@babel/eslint-parser": "7.28.5",
    "@eslint/compat": "2.0.0",
    "@eslint/js": "9.39.1",
    "@intlify/core": "11.2.2",
    "@rushstack/eslint-patch": "1.15.0",
    "@vitejs/plugin-vue": "6.0.2",
    "@vitest/coverage-v8": "4.0.14",
    "@vue/babel-preset-app": "5.0.9",
    "@vue/compiler-dom": "3.5.25",
    "@vue/compiler-sfc": "3.5.25",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/runtime-dom": "3.5.25",
    "@vue/server-renderer": "3.5.25",
    "@vue/shared": "3.5.25",
    "@vue/test-utils": "2.4.6",
    "css": "3.0.0",
    "dayjs": "1.11.19",
    "eslint": "9.39.1",
    "eslint-plugin-local-rules": "3.0.2",
    "eslint-plugin-vue": "10.6.1",
    "globals": "16.5.0",
    "jsdom": "27.2.0",
    "prettier": "3.6.2",
    "url-template": "3.1.1",
    "vite": "7.2.4",
    "vitest": "4.0.14"
  },
  "overrides": {
    "lodash": "lodash-es",
    "uri-js": "npm:uri-js-replace"
  }
}
