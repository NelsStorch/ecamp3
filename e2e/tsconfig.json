{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/utils/*": ["utils/*"],
      "@/tests/*": ["tests/*"],
      "@/test-data/*": ["test-data/*"],
      "@/shared-types/*": ["shared-types/*"]
    },
    "ignoreDeprecations": "6.0"
  },
  "include": ["tests/**/*.ts", "utils/**/*.ts", "playwright.config.ts", "pdfjs.d.ts"],
  "exclude": ["node_modules", "dist"]
}
