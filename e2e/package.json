    "cypress-terminal-report": "7.2.1",
    "cypress-wait-until": "3.0.2",
    "eslint": "9.35.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-cypress": "5.1.1",
    "eslint-plugin-prettier": "5.5.4",
    "globals": "16.4.0",
    "pdfjs-dist": "5.4.149",
    "prettier": "3.6.2"
  },
