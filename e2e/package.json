{
  "name": "@ecamp3/e2e",
  "private": true,
  "scripts": {
    "test:ui": "playwright test --ui",
    "test": "playwright test",
    "lint": "npm run lint:eslint && npm run lint:prettier && npm run typecheck",
    "lint:eslint": "eslint --fix .",
    "lint:prettier": "prettier --write --ignore-path .gitignore **/*.{js,mjs,ts,json,md}",
    "lint:check": "npm run lint:check:eslint && npm run lint:check:prettier",
    "lint:check:eslint": "eslint . --max-warnings 0",
    "lint:check:prettier": "prettier --check --ignore-path .gitignore **/*.{js,mjs,ts,json,md}",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/compat": "2.1.0",
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.59.1",
    "@types/node": "24.12.4",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-playwright": "2.10.3",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.6.0",
    "pdfjs-dist": "5.7.284",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4"
  },
  "overrides": {
    "uri-js": "npm:uri-js-replace"
  }
}
